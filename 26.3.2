<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LogiqueCode Product Suite Update</title>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: #0f172a;
  color: #e2e8f0;
}

header {
  text-align: center;
  padding: 80px 20px;
  background: linear-gradient(135deg, #1e293b, #0f172a);
}

header h1 {
  font-size: 42px;
  margin-bottom: 10px;
}

header p {
  font-size: 18px;
  color: #94a3b8;
}

.container {
  max-width: 1100px;
  margin: auto;
  padding: 40px 20px;
}

.card {
  background: #1e293b;
  border-radius: 16px;
  padding: 25px;
  margin-bottom: 30px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
}

.card h2 {
  margin-top: 0;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}

.feature {
  background: #0f172a;
  padding: 15px;
  border-radius: 10px;
}

.feature h4 {
  margin: 0 0 8px 0;
}

.footer {
  text-align: center;
  padding: 30px;
  color: #64748b;
}
</style>
</head>

<body>

<header>
  <h1>LogiqueCode Product Suite Update</h1>
  <p>GPMA | LMS | DPMS – Powering Smarter Operations</p>
</header>

<div class="container">

  <!-- GPMA -->
  <div class="card">
    <h2>GPMA – Garment Production Management Application Excellence</h2>
    <div class="grid">
      <div class="feature">
        <h4>Spare Requisition</h4>
        <p>Improved workflow with better tracking and faster approvals.</p>
      </div>
      <div class="feature">
        <h4>Production Sheet</h4>
        <p>Integrated material requisition within production planning.</p>
      </div>
      <div class="feature">
        <h4>Approval System</h4>
        <p>Structured and configurable approval hierarchy.</p>
      </div>
      <div class="feature">
        <h4>Role-Based Access</h4>
        <p>Secure module-level access control.</p>
      </div>
    </div>
  </div>

  <!-- LMS -->
  <div class="card">
    <h2>LMS – Smart Campus Management</h2>
    <div class="grid">
      <div class="feature">
        <h4>Visitor Management</h4>
        <p>Digitized and secure campus visitor tracking.</p>
      </div>
      <div class="feature">
        <h4>Enquiry Dashboard</h4>
        <p>Improved visibility into admissions pipeline.</p>
      </div>
      <div class="feature">
        <h4>Batch UI</h4>
        <p>Modern and intuitive batch management interface.</p>
      </div>
      <div class="feature">
        <h4>Attendance</h4>
        <p>Subject-wise detailed attendance tracking.</p>
      </div>
      <div class="feature">
        <h4>Hostel Management</h4>
        <p>Better room allocation and occupancy tracking.</p>
      </div>
    </div>
  </div>

  <!-- DPMS -->
  <div class="card">
    <h2>DPMS – Clinical Efficiency</h2>
    <div class="grid">
      <div class="feature">
        <h4>Prescription Templates</h4>
        <p>Faster and standardized prescriptions.</p>
      </div>
      <div class="feature">
        <h4>Custom Diseases</h4>
        <p>Flexible disease configuration for hospitals.</p>
      </div>
      <div class="feature">
        <h4>Procedures Control</h4>
        <p>Enable/disable services based on availability.</p>
      </div>
    </div>
  </div>

</div>

<div class="footer">
  <p>© 2026 LogiqueCode | Product Engineering & SaaS Solutions</p>
</div>

</body>
</html>
